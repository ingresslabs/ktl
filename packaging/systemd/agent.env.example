# Copy to /etc/torque/agent.env and chmod 0600 before enabling the services.
#
# Generate distinct tokens:
#   openssl rand -hex 32

TORQUE_REMOTE_TOKEN=
TORQUE_MCP_TOKEN=
TORQUE_AGENT_LISTEN=:7443
TORQUE_AGENT_HTTP_LISTEN=127.0.0.1:8081
TORQUE_AGENT_MIRROR_STORE=/var/lib/torque/agent/mirror.sqlite
TORQUE_AGENT_SANDBOX_BIN=nsjail
TORQUE_AGENT_SANDBOX_CONFIG=
TORQUE_MCP_LISTEN=127.0.0.1:7331
TORQUE_MCP_REMOTE_AGENT=127.0.0.1:7443
KUBECONFIG=/etc/torque/kubeconfig
TORQUE_KUBE_CONTEXT=
